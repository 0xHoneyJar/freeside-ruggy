# freeside-ruggy environment

# ─── stub mode (V1 default) ─────────────────────────────────────────
# When true, ruggy uses synthetic ActivitySummary + canned LLM digest.
# When false, ruggy hits real score-api + freeside agent-gateway.
STUB_MODE=true

# ─── score-api (zerker) ──────────────────────────────────────────────
# Used when STUB_MODE=false
SCORE_API_URL=https://score-api-production.up.railway.app
SCORE_API_KEY=                         # set when zerker provides one

# ─── freeside agent-gateway (jani — production path) ───────────────
# Used when STUB_MODE=false AND ANTHROPIC_API_KEY is empty
FREESIDE_BASE_URL=https://api.freeside.0xhoneyjar.xyz
FREESIDE_API_KEY=                      # set when jani provisions
FREESIDE_AGENT_MODEL=reasoning         # cheap | fast-code | reviewer | reasoning | architect

# ─── anthropic direct (V0 testing path) ────────────────────────────
# Used when STUB_MODE=false AND ANTHROPIC_API_KEY is set.
# Bypasses freeside (no budget accounting, no model-tier routing).
# Use to validate ruggy's voice while jani's freeside key is pending.
# When freeside key lands, clear ANTHROPIC_API_KEY to switch to production.
ANTHROPIC_API_KEY=                     # sk-ant-... (your testing key)
ANTHROPIC_MODEL=claude-sonnet-4-6      # claude-opus-4-7 | claude-sonnet-4-6 | claude-haiku-4-5-20251001

# ─── discord delivery ───────────────────────────────────────────────
# Webhook URL for the target channel (e.g. #midi-watch in honey jar guild)
# When blank, ruggy dry-runs to stdout instead of posting
DISCORD_WEBHOOK_URL=

# ─── target ─────────────────────────────────────────────────────────
WORLD_ID=mibera
APP_ID=midi
DIGEST_CADENCE=weekly                  # weekly | daily | manual
DIGEST_DAY=sunday                      # day of week (when cadence=weekly)
DIGEST_HOUR_UTC=0                      # hour (UTC, 0-23)

# ─── meta ───────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
