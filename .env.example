# freeside-ruggy environment

# ─── stub mode (data side; LLM flips on key presence) ──────────────
# When true, ruggy uses synthetic ZoneDigest payloads.
# When false, ruggy hits real score-mcp (requires MCP_KEY).
STUB_MODE=true

# ─── score-mcp (zerker — production data path) ─────────────────────
# /mcp endpoint exposed by score-api when zerker deploys feature/score-mcp.
SCORE_API_URL=https://score-api-production.up.railway.app
SCORE_API_KEY=                         # required for legacy /v1 routes
MCP_KEY=                               # X-MCP-Key header for /mcp tool calls

# ─── freeside agent-gateway (jani — production LLM path) ──────────
FREESIDE_BASE_URL=https://api.freeside.0xhoneyjar.xyz
FREESIDE_API_KEY=                      # set when jani provisions
FREESIDE_AGENT_MODEL=reasoning         # cheap | fast-code | reviewer | reasoning | architect

# ─── anthropic-direct (V0 LLM testing path) ────────────────────────
# When ANTHROPIC_API_KEY is set, LLM calls go to Anthropic directly,
# bypassing freeside (no budget accounting). Use for voice validation
# while jani's freeside key is pending.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6      # claude-opus-4-7 | claude-sonnet-4-6 | claude-haiku-4-5-20251001

# ─── Discord delivery — bot client OR webhook fallback ─────────────
# When DISCORD_BOT_TOKEN is set, ruggy logs in as the Ruggy bot user
# and posts to per-zone channels via Gateway. When unset, falls back
# to webhook (single channel, V0 testing path).
DISCORD_BOT_TOKEN=                     # bot token from Discord Developer Portal
DISCORD_WEBHOOK_URL=                   # legacy fallback (single channel)

# ─── Per-zone channel IDs (used when DISCORD_BOT_TOKEN is set) ─────
DISCORD_CHANNEL_STONEHENGE=1498822402900230294
DISCORD_CHANNEL_BEAR_CAVE=1498822450316578907
DISCORD_CHANNEL_EL_DORADO=1498822480587002038
DISCORD_CHANNEL_OWSLEY_LAB=1498822512442609694

# ─── target / cadence ──────────────────────────────────────────────
# Comma-separated subset of zones to fire. Unset = all 4 zones.
ZONES=
DIGEST_CADENCE=weekly                  # weekly | daily | manual
DIGEST_DAY=sunday                      # day of week (when cadence=weekly)
DIGEST_HOUR_UTC=0                      # hour (UTC, 0-23)

# ─── meta ──────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
